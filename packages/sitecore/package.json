    "@types/node": "^22.15.3",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.7",
    "eslint": "^9.39.1",
    "typescript": "~5.4.0"
  },
  "dependencies": {
    "@repo/ui": "*",
    "@sitecore-jss/sitecore-jss-nextjs": "~22.11.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
